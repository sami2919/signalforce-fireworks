# RL GTM Engine — Environment Variables
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Signal Scanners
# ---------------------------------------------------------------------------

# GitHub API (required for GitHub signal scanning)
GITHUB_TOKEN=

# SerpAPI key (for job posting scanner and G2 review scanner)
SERPAPI_KEY=

# Semantic Scholar (optional — improves rate limits for arXiv scanner)
SEMANTIC_SCHOLAR_KEY=

# ---------------------------------------------------------------------------
# Contact Enrichment (at least one required for enrichment scanner)
# ---------------------------------------------------------------------------

# Apollo.io API key
APOLLO_API_KEY=

# Hunter.io API key
HUNTER_API_KEY=

# Prospeo API key
PROSPEO_API_KEY=

# ---------------------------------------------------------------------------
# Outbound & CRM
# ---------------------------------------------------------------------------

# Instantly.ai API key (for email sequencing)
INSTANTLY_API_KEY=

# HubSpot API key (for CRM sync)
HUBSPOT_API_KEY=

# ---------------------------------------------------------------------------
# AI / ML
# ---------------------------------------------------------------------------

# OpenAI API key (for email generation)
OPENAI_API_KEY=

# Anthropic API key (for marops lifecycle brief generation)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Data & Verification
# ---------------------------------------------------------------------------

# Clay API key
CLAY_API_KEY=

# ZeroBounce API key (for email verification)
ZEROBOUNCE_API_KEY=

# ---------------------------------------------------------------------------
# Pipeline Behaviour
# ---------------------------------------------------------------------------

# Number of days to look back when scanning for signals (default: 7)
SCAN_LOOKBACK_DAYS=7

# Minimum signal strength to include (1=WEAK, 2=MODERATE, 3=STRONG; default: 1)
MIN_SIGNAL_STRENGTH=1

# Log level (DEBUG, INFO, WARNING, ERROR; default: INFO)
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# G2 Authenticated Scanner
# ---------------------------------------------------------------------------
# Your G2 session cookie — lets the scanner read reviews as you, bypassing
# IP blocks. Get it in 30 seconds:
#   1. Log into g2.com in Chrome
#   2. DevTools (F12) → Network → reload page → click any g2.com request
#   3. Headers tab → find "Cookie:" → copy the full value
#   4. Paste below (keep the quotes)
#
# Cookies expire after ~7 days. Re-copy if you start seeing 403 errors.
G2_SESSION_COOKIE=""

# ---------------------------------------------------------------------------
# Fireworks AI (alternative LLM backend via OpenAI-compatible API)
# ---------------------------------------------------------------------------
# Fireworks API key (for Fireworks-backed agent inference)
FIREWORKS_API_KEY=
# Fireworks inference base URL (default: https://api.fireworks.ai/inference/v1)
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Fireworks model ID (default: accounts/fireworks/models/glm-5p2)
FIREWORKS_MODEL=accounts/fireworks/models/glm-5p2
